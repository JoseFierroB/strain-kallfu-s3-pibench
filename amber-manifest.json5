{
  agent: {
    name: "Strain Kallfu Zero - Pi-Bench",
    description: "Multi-layer purple agent with deterministic pre/post pipeline. Uses DeepSeek V3.2 + Llama 4 Maverick fallback. Policy rule extraction, intent classification, JSON validation, adversarial input detection.",
    image: "ghcr.io/josefierrob/strain-kallfu-s3-pibench:main",
    a2a: { port: 9009 },
    env: ["NEBIUS_API_KEY", "OPENAI_API_KEY"],
  },
  exports: {
    agent: {
      a2a: true,
    },
  },
}
